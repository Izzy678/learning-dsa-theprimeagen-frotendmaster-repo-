{
    "compilerOptions": {
        "outDir": "dist",
        "allowJs": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "noImplicitReturns": true,
        "esModuleInterop": true,
        "target": "esnext",
        "module": "commonjs",
        "baseUrl": "src",
        "paths": {
            "day-1/*": [
                "day-1/*"
            ],
            "@code/*": [
                "day1/*"
            ],
            "@scripts/*": [
                "../scripts/*"
            ]
        }
    },
    "include": [
        "./src/**/*",
        "./scripts/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
